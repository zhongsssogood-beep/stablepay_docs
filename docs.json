{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "StablePay site test",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book-open-cover",
          "href": "https://mintlify.com/docs"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://mintlify.com/blog"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "产品文档",
            "pages": [
              "product-docs/checkout-suggestions",
              "product-docs/payments",
              "product-docs/subscriptions",
              "product-docs/refunds",
              "product-docs/currency-conversion",
              "product-docs/account-management"
            ]
          },
          {
            "group": "SaaS平台接入",
            "pages": [
              "saas-integrations/shopify",
              "saas-integrations/woocommerce",
              "saas-integrations/shoplazza",
              "saas-integrations/shopyy"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "支付服务",
            "pages": [
              "api-reference/payments/create",
              "api-reference/payments/get",
              "api-reference/payments/list"
            ]
          },
          {
            "group": "订阅服务",
            "pages": [
              "api-reference/subscriptions/create",
              "api-reference/subscriptions/get",
              "api-reference/subscriptions/cancel"
            ]
          },
          {
            "group": "退款服务",
            "pages": [
              "api-reference/refunds/create",
              "api-reference/refunds/get"
            ]
          },
          {
            "group": "Webhook",
            "pages": [
              "api-reference/webhooks/introduction",
              "api-reference/webhooks/events"
            ]
          }
        ]
      },
      {
        "tab": "FAQ"
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@stablepay.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.stablepay.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/stablepay",
      "github": "https://github.com/stablepay",
      "linkedin": "https://linkedin.com/company/stablepay"
    }
  }
}
